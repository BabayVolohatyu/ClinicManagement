@using ClinicManagement.Services
@inject IAuthService AuthService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClinicManagement.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">ClinicManagement</a>

                <!-- REMOVE THE OUTER CONDITION - Always show navbar structure -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between" id="mainNavbar">
                    <!-- Conditionally show menu items only for authenticated users -->
                    @if (AuthService.IsAuthenticated())
                    {
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <!-- Facilities -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="facilitiesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Facilities
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="facilitiesDropdown">
                                    <li><a class="dropdown-item" asp-controller="Cabinet" asp-action="Index">Cabinet</a></li>
                                    <li><a class="dropdown-item" asp-controller="CabinetType" asp-action="Index">Cabinet Type</a></li>
                                </ul>
                            </li>

                            <!-- Health -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="healthDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Health
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="healthDropdown">
                                    <li><a class="dropdown-item" asp-controller="Diagnosis" asp-action="Index">Diagnosis</a></li>
                                    <li><a class="dropdown-item" asp-controller="Procedure" asp-action="Index">Procedure</a></li>
                                    <li><a class="dropdown-item" asp-controller="Sickness" asp-action="Index">Sickness</a></li>
                                    <li><a class="dropdown-item" asp-controller="SicknessProcedure" asp-action="Index">SicknessProcedure</a></li>
                                    <li><a class="dropdown-item" asp-controller="SicknessSymptom" asp-action="Index">SicknessSymptom</a></li>
                                    <li><a class="dropdown-item" asp-controller="SicknessTreatment" asp-action="Index">SicknessTreatment</a></li>
                                    <li><a class="dropdown-item" asp-controller="Symptom" asp-action="Index">Symptom</a></li>
                                    <li><a class="dropdown-item" asp-controller="Treatment" asp-action="Index">Treatment</a></li>
                                </ul>
                            </li>

                            <!-- Humans -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="humansDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Humans
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="humansDropdown">
                                    <li><a class="dropdown-item" asp-controller="DistrictDoctor" asp-action="Index">DistrictDoctor</a></li>
                                    <li><a class="dropdown-item" asp-controller="Doctor" asp-action="Index">Doctor</a></li>
                                    <li><a class="dropdown-item" asp-controller="Patient" asp-action="Index">Patient</a></li>
                                    <li><a class="dropdown-item" asp-controller="Person" asp-action="Index">Person</a></li>
                                    <li><a class="dropdown-item" asp-controller="Specialty" asp-action="Index">Specialty</a></li>
                                </ul>
                            </li>

                            <!-- Info -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="infoDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Info
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="infoDropdown">
                                    <li><a class="dropdown-item" asp-controller="Address" asp-action="Index">Address</a></li>
                                    <li><a class="dropdown-item" asp-controller="Appointment" asp-action="Index">Appointment</a></li>
                                    <li><a class="dropdown-item" asp-controller="DoctorOnCallStatus" asp-action="Index">DoctorOnCallStatus</a></li>
                                    <li><a class="dropdown-item" asp-controller="DoctorProcedure" asp-action="Index">DoctorProcedure</a></li>
                                    <li><a class="dropdown-item" asp-controller="Schedule" asp-action="Index">Schedule</a></li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <!-- Show only Home for unauthenticated users -->
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                        </ul>
                    }

                    <!-- User Info / Login - This part remains the same -->
                    <ul class="navbar-nav">
                        @if (AuthService.IsAuthenticated())
                        {
                            var currentUser = AuthService.GetCurrentUser();
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @currentUser?.FirstName ?? "User"
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Login" asp-action="Logout">Logout</a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Login" asp-action="Index">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Register" asp-action="Index">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>